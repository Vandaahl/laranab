# These are specific to Laranab
NEWZNAB_APIS=
TZ=Europe/Amsterdam

# DB credentials for MariaDB container - change the passwords from the default values before creating the containers
MARIADB_ROOT_PASSWORD=root_password
MARIADB_USER=laranab
MARIADB_PASSWORD=password
MARIADB_DATABASE=laravel

# DB credentials for app container
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE="${MARIADB_DATABASE}"
DB_USERNAME="${MARIADB_USER}"
DB_PASSWORD="${MARIADB_PASSWORD}"

# These are for the Laravel app
APP_NAME=Laranab
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
